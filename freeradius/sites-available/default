server default {

    listen {
        type   = auth
        ipaddr = *
        port   = 1812
    }

    listen {
        type   = acct
        ipaddr = *
        port   = 1813
    }

    authorize {
        rest

        if (ok || updated) {
            update control {
                &Auth-Type := rest
            }
        }
        else {
            reject
        }
    }

    authenticate {
        Auth-Type rest {
            rest
        }
    }

    accounting {
        rest
        ok
    }

    post-auth {
        update reply {
            &Reply-Message = "Welcome, %{User-Name}"
        }

        Post-Auth-Type REJECT {
            update reply {
                &Reply-Message = "Access denied"
            }
        }
    }
}
